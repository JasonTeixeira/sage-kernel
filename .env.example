# --- Database (kernel's own state; sqlite is the zero-config default) ---
SAGE_DB_PROVIDER=sqlite
DATABASE_URL=

# --- Analyzing YOUR OTHER repos ---
# Colon-separated parent dirs the kernel is allowed to analyze. Required to point
# the server (whose cwd is the kernel checkout) at projects outside the kernel.
# Without it, foreign projectPath/targetRoot values are refused by the path gate.
SAGE_PROFILE_ALLOWED_ROOTS=/Users/Sage/code:/Users/Sage/Documents

# --- Autonomous self-healing / repair loop ---
# The model CLI the repairer shells out to. Unset => repair returns
# blocked_not_implemented (honest no-op), it does not fake a fix.
#   e.g. node providers/claude-agent.mjs  (Claude Code CLI)
#        node providers/codex-agent.mjs   (OpenAI Codex CLI, non-Claude)
SAGE_AGENT_COMMAND=
# Optional adversarial verifier command (majority-of-3 confirm of a repair).
SAGE_VERIFIER_COMMAND=
# Optional: sign the proof ledger (HMAC) for tamper-evidence on shared machines.
SAGE_LEDGER_KEY=

# --- Misc ---
PLAYWRIGHT_MCP_EXTENSION_TOKEN=
