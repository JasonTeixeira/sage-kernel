{
  "name": "sage-kernel",
  "version": "0.3.0",
  "description": "Sage Kernel OS: a personal MCP-powered engineering operating system for app, AI, infra, QA, and production workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JasonTeixeira/sage-kernel.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bugs": {
    "url": "https://github.com/JasonTeixeira/sage-kernel/issues"
  },
  "homepage": "https://github.com/JasonTeixeira/sage-kernel#readme",
  "keywords": [
    "mcp",
    "engineering-os",
    "automation",
    "qa",
    "templates",
    "sqlite",
    "agent-tools"
  ],
  "type": "module",
  "files": [
    "apps/dashboard/README.md",
    "apps/dashboard/scripts",
    "apps/dashboard/server.mjs",
    "apps/mcp-server",
    "apps/worker",
    "assets",
    "bin",
    "catalog",
    "docs",
    "examples",
    "packages",
    "scripts",
    ".env.example",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "sage": "bin/sage.mjs"
  },
  "scripts": {
