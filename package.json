    "db:restore": "node packages/db/scripts/db-restore.mjs",
    "db:export": "node packages/db/scripts/db-export-json.mjs",
    "db:import": "node packages/db/scripts/db-import-json.mjs",
    "db:postgres:schema": "node packages/db/scripts/db-export-postgres.mjs",
