    "jobs:validate": "node apps/worker/scripts/validate-jobs.mjs",
    "jobs:enqueue": "node apps/worker/scripts/jobs-enqueue.mjs",
    "jobs:next": "node apps/worker/scripts/jobs-next.mjs",
    "worker:daemon": "node apps/worker/scripts/worker-daemon.mjs",
    "jobs:list": "node apps/worker/scripts/jobs-list.mjs",
    "jobs:run": "node apps/worker/scripts/jobs-run.mjs",
    "jobs:runs": "node apps/worker/scripts/runs-list.mjs",
    "jobs:show": "node apps/worker/scripts/runs-show.mjs",
    "dashboard:build": "node apps/dashboard/scripts/build-dashboard.mjs",
    "dashboard:serve": "node apps/dashboard/server.mjs",
    "dashboard:browser-check": "node apps/dashboard/scripts/browser-check.mjs",
    "dashboard:e2e": "node scripts/dashboard-e2e.mjs",
    "infra:emit": "node packages/infra/scripts/infra-emit.mjs",
    "dogfood:build": "node scripts/dogfood-build.mjs",
    "dogfood:prod": "node scripts/dogfood-production-audit.mjs",
    "release:pack": "npm pack --dry-run",
    "release:check": "node scripts/release-check.mjs",
    "release:provenance": "node scripts/validate-release-provenance.mjs",
    "public:validate": "node scripts/validate-public-surface.mjs",
    "verify:fresh-install": "node scripts/verify-fresh-install.mjs",
    "sage:smoke": "node bin/sage.mjs status",
    "template:list": "node packages/templates/scripts/template-list.mjs",
    "template:scaffold": "node packages/templates/scripts/template-scaffold-v2.mjs",
    "template:validate-blueprints": "node packages/templates/scripts/validate-blueprints.mjs",
    "phase:status": "node scripts/phase-status.mjs",
    "postgres:integration": "node --test tests/postgres-integration.test.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  }
}
