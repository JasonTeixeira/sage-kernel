    "adapters:smoke": "node packages/intelligence/scripts/adapters-smoke.mjs",
    "runbooks:validate": "node packages/intelligence/scripts/runbooks-validate.mjs",
    "runbooks:list": "node packages/intelligence/scripts/runbooks-list.mjs",
