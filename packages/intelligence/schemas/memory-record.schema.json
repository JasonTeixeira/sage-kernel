{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sage-kernel.dev/schemas/intelligence/memory-record.schema.json",
  "title": "Sage Kernel Memory Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "projectId", "kind", "source", "actor", "confidence", "observedAt", "content", "provenance"],
  "properties": {
    "id": { "type": "string", "pattern": "^mem_[a-z0-9][a-z0-9_-]*$" },
    "projectId": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["episode", "fact", "decision", "test_result", "approval", "release_event"] },
    "source": { "type": "string", "enum": ["user", "agent", "tool", "test", "ci", "git", "dashboard", "mcp"] },
    "actor": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "observedAt": { "type": "string", "format": "date-time" },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "expiresAt": { "type": "string", "format": "date-time" },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "details": { "type": "object" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceType", "evidenceRef"],
      "properties": {
        "evidenceType": { "type": "string", "enum": ["command", "file", "url", "manual", "ci_run", "mcp_call"] },
        "evidenceRef": { "type": "string", "minLength": 1 },
        "hash": { "type": "string" }
      }
    }
  }
}

